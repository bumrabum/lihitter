# ── Server ────────────────────────────────────────────────────────────────
# Port the Express web UI/API listens on (default: 3000)
PORT=3001
# LOCAL = disable basic auth (dev only). Any other value / omitted = auth required
APP_MODE=LOCAL
# Basic-auth credentials for the web UI (used when APP_MODE is not LOCAL)
AUTH_USER=admin
AUTH_PASSWORD=changeme
# Shared secret to validate incoming webhook calls
WEBHOOK_SECRET=replace-me

# ── File paths (relative to project root) ────────────────────────────────
# Job-filtering rules definition
RULES_PATH=./rules.json
# Optional saved LinkedIn cookies — only used for the Voyager API fallback
# when a public job page returns no content. The app works without it.
SESSION_PATH=./session.json
# SQLite database with processed jobs/results
DB_PATH=./results.db
# App settings file (optional, default: ./settings.json)
# SETTINGS_PATH=./settings.json

# ── Gmail IMAP (reads LinkedIn job-alert emails) ─────────────────────────
# Gmail account to fetch job-alert emails from
GMAIL_USER=your-gmail@gmail.com
# Gmail App Password (Google Account → Security → App passwords), NOT the account password
GMAIL_APP_PASSWORD=your-app-password
# Gmail search query used to select which emails to process
GMAIL_QUERY=from:linkedin newer_than:7d

# ── LLM (job matching / analysis) ────────────────────────────────────────
# Provider for LLM calls: opencode (default) or mock
# LLM_PROVIDER=opencode
# Model used by the opencode provider (default: github-copilot/gpt-4.1)
# OPENCODE_MODEL=github-copilot/gpt-4.1
